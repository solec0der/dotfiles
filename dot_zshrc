# GKE k9s functions — background-refresh gcloud token every 45min to prevent auth expiry
# Use `function` keyword to prevent alias expansion of `kk` prefix
function kk-ct() {
  while true; do gcloud auth print-access-token > /dev/null 2>&1; sleep 2700; done &
  local refresh_pid=$!
  k9s --context gke_ppcloud-dev_europe-west3_ppcloud-dev-cluster -n ct
  kill $refresh_pid 2>/dev/null
}

function kk-review() {
  while true; do gcloud auth print-access-token > /dev/null 2>&1; sleep 2700; done &
