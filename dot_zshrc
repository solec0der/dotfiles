# ─── Options ──────────────────────────────────────────────
unsetopt AUTO_CD
setopt HIST_IGNORE_ALL_DUPS HIST_SAVE_NO_DUPS SHARE_HISTORY
HISTSIZE=10000
SAVEHIST=10000
HISTFILE="$HOME/.zsh_history"

# ─── Zinit (replaces Oh-My-Zsh) ──────────────────────────
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
[ ! -d "$ZINIT_HOME" ] && mkdir -p "$(dirname $ZINIT_HOME)" \
  && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# Plugins — turbo mode (loads after prompt, keeps startup fast)
zinit wait lucid for \
  atinit"zicompinit; zicdreplay" \
    zdharma-continuum/fast-syntax-highlighting \
  atload"ZSH_AUTOSUGGEST_ACCEPT_WIDGETS+=(desel-forward-char desel-end-of-line); ZSH_AUTOSUGGEST_PARTIAL_ACCEPT_WIDGETS+=(desel-forward-word); _zsh_autosuggest_start" \
    zsh-users/zsh-autosuggestions \
  blockf atpull'zinit creinstall -q .' \
    zsh-users/zsh-completions

# globalias (expand aliases on space — same as Oh-My-Zsh plugin)
zinit snippet OMZP::globalias

# OMZ lib snippets (l, la, ll, .., ..., md, rd, etc.)
zinit snippet OMZL::directories.zsh
zinit snippet OMZL::theme-and-appearance.zsh

# ─── Key Bindings ─────────────────────────────────────────
bindkey -e                        # Force emacs keybindings (override EDITOR=nvim)
bindkey "^[[1;3D" backward-word    # Option+Left
bindkey "^[[1;3C" forward-word     # Option+Right

# ─── Natural Text Selection (Warp-like) ──────────────────
zle_highlight+=(region:standout)

# Shift-select: start/extend selection while moving
_sel() { ((REGION_ACTIVE)) || zle set-mark-command; zle $1 }
for w in backward-{char,word} forward-{char,word} beginning-of-line end-of-line; do
  eval "sel-$w() { _sel $w }; zle -N sel-$w"
done

# Plain movement clears selection
_desel() { REGION_ACTIVE=0; zle $1 }
for w in backward-{char,word} forward-{char,word} beginning-of-line end-of-line; do
  eval "desel-$w() { _desel $w }; zle -N desel-$w"
done

# Shift+Arrow → select characters
bindkey "^[[1;2D" sel-backward-char         # Shift+Left
bindkey "^[[1;2C" sel-forward-char          # Shift+Right

# Option+Shift+Arrow → select words
bindkey "^[[1;4D" sel-backward-word         # Option+Shift+Left
bindkey "^[[1;4C" sel-forward-word          # Option+Shift+Right

# Cmd+Shift+Arrow → select to line boundary (Ghostty sends custom seq)
bindkey "^[[1;10D" sel-beginning-of-line    # Cmd+Shift+Left
bindkey "^[[1;10C" sel-end-of-line          # Cmd+Shift+Right

# Plain Arrow / Option+Arrow → move & deselect
bindkey "^[[D"    desel-backward-char
bindkey "^[[C"    desel-forward-char
bindkey "^[[1;3D" desel-backward-word       # Option+Left
bindkey "^[[1;3C" desel-forward-word        # Option+Right
bindkey "^A"      desel-beginning-of-line   # Ctrl-A / Cmd+Left
bindkey "^E"      desel-end-of-line         # Ctrl-E / Cmd+Right

# Backspace / Delete → remove selection or single char
del-sel-or-bs() { ((REGION_ACTIVE)) && zle kill-region || zle backward-delete-char }
del-sel-or-dc() { ((REGION_ACTIVE)) && zle kill-region || zle delete-char }
zle -N del-sel-or-bs; zle -N del-sel-or-dc
bindkey "^?"    del-sel-or-bs               # Backspace
bindkey "^[[3~" del-sel-or-dc               # Delete

# Typing replaces selection
self-insert() { ((REGION_ACTIVE)) && zle kill-region; zle .self-insert }
zle -N self-insert

# Cmd+C → copy selection to clipboard or interrupt (Ghostty sends custom seq)
copy-or-interrupt() {
  if ((REGION_ACTIVE)); then
    zle copy-region-as-kill
    print -rn -- "$CUTBUFFER" | pbcopy
    REGION_ACTIVE=0
  else
    zle send-break
  fi
}
zle -N copy-or-interrupt
bindkey "^[[CC" copy-or-interrupt

# ─── Completions ──────────────────────────────────────────
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
fpath+=~/.zfunc

